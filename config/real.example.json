{
  "server": {"host": "127.0.0.1", "port": 8000, "max_active_sessions": 1},
  "stream": {
    "silence_timeout_ms": 1000,
    "max_turn_duration_seconds": 30,
    "silence_rms_threshold": 0.01,
    "input_sample_rate": 16000,
    "input_channels": 1,
    "input_sample_width_bytes": 2,
    "sentence_min_chars": 8,
    "sentence_max_chars": 24,
    "sentence_max_wait_ms": 500
  },
  "vad": {
    "engine": "rms",
    "interrupt_min_speech_ms": 80,
    "interrupt_rms_threshold": 0.02
  },
  "retention": {"max_runs": 100},
  "limits": {"morpheus_max_concurrency": 1, "subprocess_terminate_grace_seconds": 2},
  "face_stitching": {
    "enabled": true,
    "overlap_frames": 8,
    "reset_on_new_turn": true,
    "record_boundary_metrics": true
  },
  "eye_continuity": {
    "enabled": true,
    "eye_smooth_channel_indices": [],
    "blink_enabled": false,
    "blink_channel_indices": [],
    "overlap_frames": 6,
    "record_boundary_metrics": true,
    "blink_interval_min_sec": 2.5,
    "blink_interval_max_sec": 6.0,
    "blink_duration_frames": 5,
    "blink_strength": 1.0,
    "seed": 42,
    "reset_blink_on_new_turn": false
  },
  "history": {
    "enabled": true,
    "max_turn_pairs": 6,
    "max_chars": 3000
  },
  "expression": {
    "enabled": false,
    "channel_mapping_path": "config/expression_channels.example.json",
    "max_delta": 0.3,
    "profiles": {
      "happy": {"mouth_smile_left": 0.15, "mouth_smile_right": 0.15},
      "friendly": {"mouth_smile_left": 0.08, "mouth_smile_right": 0.08},
      "surprised": {"jaw_open": 0.18},
      "sad": {"mouth_frown_left": 0.1, "mouth_frown_right": 0.1},
      "thinking": {"brow_down_left": 0.08, "brow_down_right": 0.08}
    }
  },
  "adapters": {
    "asr": {"provider": "faster-whisper", "timeout_seconds": 5},
    "llm": {"provider": "ollama", "timeout_seconds": 5},
    "tts": {"provider": "piper", "timeout_seconds": 5},
    "audio2face": {"provider": "morpheus", "timeout_seconds": 5},
    "ue5": {"provider": "morpheus-raw", "timeout_seconds": 5}
  },
  "providers": {
    "faster_whisper": {
      "model": "base",
      "device": "cpu",
      "compute_type": "int8",
      "language": "zh"
    },
    "ollama": {
      "base_url": "http://127.0.0.1:11434",
      "model": "qwen2.5:3b",
      "timeout_seconds": 120,
      "keep_alive": "30m",
      "num_ctx": 2048,
      "num_predict": 96,
      "temperature": 0.3,
      "prewarm": true
    },
    "piper": {
      "runtime": "python",
      "executable": "",
      "args": ["--model", "{model_path}", "--output_file", "{output_path}"],
      "model_path": "",
      "config_path": "",
      "use_cuda": false,
      "cwd": null,
      "timeout_seconds": 120
    },
    "morpheus": {
      "executable": "conda",
      "args": [
        "run",
        "-n",
        "lyyMor",
        "",
        "--input",
        "{input_path}",
        "--output-dir",
        "{output_dir}"
      ],
      "cwd": "/home/hailab/liuyiyu/head-project/Morpheus-Software",
      "output_npy_glob": "*.npy",
      "output_json_glob": "*.json",
      "timeout_seconds": 300
    }
  },
  "storage": {"root": "data"}
}
