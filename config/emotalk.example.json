{
  "server": {"host": "127.0.0.1", "port": 8000, "max_active_sessions": 1},
  "stream": {
    "silence_timeout_ms": 1000,
    "max_turn_duration_seconds": 30,
    "silence_rms_threshold": 0.01,
    "input_sample_rate": 16000,
    "input_channels": 1,
    "input_sample_width_bytes": 2,
    "sentence_max_chars": 80,
    "sentence_max_wait_ms": 500
  },
  "retention": {"max_runs": 100},
  "limits": {"morpheus_max_concurrency": 1, "subprocess_terminate_grace_seconds": 2},
  "adapters": {
    "asr": {"provider": "faster-whisper", "timeout_seconds": 120},
    "llm": {"provider": "ollama", "timeout_seconds": 180},
    "tts": {"provider": "piper", "timeout_seconds": 120},
    "audio2face": {"provider": "emotalk", "timeout_seconds": 300},
    "ue5": {"provider": "morpheus-raw", "timeout_seconds": 30}
  },
  "providers": {
    "faster_whisper": {
      "model": "base",
      "device": "cpu",
      "compute_type": "int8",
      "language": "zh"
    },
    "ollama": {
      "base_url": "http://127.0.0.1:11434",
      "model": "qwen2.5:3b",
      "timeout_seconds": 180
    },
    "piper": {
      "executable": "/home/user/code/端到端/.venv/bin/piper",
      "args": ["--model", "{model_path}", "--output_file", "{output_path}"],
      "model_path": "/home/user/code/端到端/models/piper/zh_CN-huayan-medium.onnx",
      "cwd": null,
      "timeout_seconds": 120
    },
    "emotalk": {
      "executable": "/home/user/miniconda3/bin/conda",
      "args": [
        "run",
        "-n",
        "emotalk",
        "python",
        "/home/user/code/EmoTalk_release/scripts/export_blendshape_from_audio.py",
        "--wav_path",
        "{input_path}",
        "--out_path",
        "{output_dir}/emotalk.npy",
        "--device",
        "cpu"
      ],
      "cwd": "/home/user/code/EmoTalk_release",
      "output_npy_glob": "*.npy",
      "output_json_glob": "*.json",
      "timeout_seconds": 300
    }
  },
  "storage": {"root": "data"}
}
